---
interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      date: Date;
      author: string;
      tags: string[];
    };
  };
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { title, description, date, author, tags } = post.data;
const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${post.id}/`}
  class:list={[
    'group relative flex flex-col rounded-xl border border-canvas-line bg-canvas p-7 transition-colors hover:border-faint hover:bg-canvas-raised',
    featured && 'sm:col-span-2',
  ]}
>
  <div class="flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-widest text-faint">
    <time datetime={date.toISOString()}>{dateStr}</time>
    <span class="h-1 w-1 rounded-full bg-faint"></span>
    <span>{author}</span>
  </div>

  <h3
    class:list={[
      'mt-4 font-display tracking-tight text-ink transition-colors group-hover:text-signal',
      featured ? 'text-3xl sm:text-4xl' : 'text-2xl',
    ]}
  >
    {title}
  </h3>

  <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{description}</p>

  <div class="mt-6 flex flex-wrap items-center gap-2">
    {
      tags.map((t) => (
        <span class="inline-flex items-center rounded-full border border-canvas-line px-2.5 py-0.5 font-mono text-[0.62rem] uppercase tracking-widest text-faint">
          {t}
        </span>
      ))
    }
    <span class="ml-auto font-mono text-xs uppercase tracking-widest text-faint transition-all group-hover:text-signal">
      Read →
    </span>
  </div>
</a>
