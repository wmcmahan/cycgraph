# cycgraph Environment Variables
# Copy to .env and fill in your values

# LLM Provider API Keys (at least one required for real agent execution)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Postgres persistence (only for @cycgraph/orchestrator-postgres)
# DATABASE_URL is the OWNER connection: migrations + the cross-tenant platform
# plane (queue, retention). The owner bypasses row-level security.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mcai

# Optional: multi-tenant enforcement. Point this at a NON-owner login role that
# has `cycgraph_app` membership (created by migration 0018). The tenant plane
# (withTenant) runs here so Postgres RLS isolates tenants. Leave UNSET for
# single-tenant / dev — the tenant plane then falls back to DATABASE_URL and
# isolation is provided by the adapters' app-level tenant_id filters.
# APP_DATABASE_URL=postgresql://cycgraph_app:...@localhost:5433/mcai

# Optional: platform plane. Point at the `cycgraph_admin` BYPASSRLS role
# (migration 0019). withPlatform (queue dequeue/reclaim, retention GC) runs here
# so cross-tenant sweeps work under FORCE RLS. Leave UNSET for dev / single-tenant
# / a superuser owner (which bypasses RLS anyway) — falls back to DATABASE_URL.
# PLATFORM_DATABASE_URL=postgresql://cycgraph_admin:...@localhost:5433/mcai

# Optional: MCP Gateway for external tool execution
# MCP_GATEWAY_URL=http://localhost:3001

# Optional: OpenTelemetry distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
