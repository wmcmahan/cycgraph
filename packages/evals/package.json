{
  "name": "@cycgraph/evals",
  "version": "0.2.0",
  "private": true,
  "description": "Automated eval harness and quality-assurance gatekeeper for @cycgraph/* packages.",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "fetch-golden": "tsx scripts/fetch-golden.ts",
    "evals": "tsx src/runner/runner.ts --mode local",
    "evals:ci": "tsx src/runner/runner.ts --mode ci"
  },
  "dependencies": {
    "@cycgraph/context-engine": "*",
    "@cycgraph/memory": "*",
    "@cycgraph/orchestrator": "*",
    "better-sqlite3": "^12.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@anthropic-ai/sdk": "^0.112.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "ai": "^6.0.116",
    "tsx": "^4.19.4",
    "typescript": "7.0.2",
    "vitest": "^4.0.18"
  }
}
